      "incident_updates": [
        {
          "id": "9gzjjffb3lll",
          "status": "identified",
          "body": "The team has identified a root cause and after initial testing, is now enacting scaling changes to help to prevent these rule execution delays. We'll monitor performance over the next 24 hours and provide an update at that time or sooner if we can confirm the improvement is in place.",
