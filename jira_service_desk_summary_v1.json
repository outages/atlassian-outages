      "id": "gx3ch20w931s",
      "name": "Jira : Incoming emails partial outage",
      "status": "monitoring",
      "created_at": "2026-06-19T22:46:56.478Z",
      "updated_at": "2026-06-19T22:46:56.648Z",
      "monitoring_at": "2026-06-19T22:46:56.629Z",
      "resolved_at": null,
      "impact": "major",
      "shortlink": "https://stspg.io/x932djl5306z",
      "started_at": "2026-06-19T22:46:56.460Z",
      "page_id": "pv54g7ltsc24",
      "incident_updates": [
        {
          "id": "qt67qn9jd6xq",
          "status": "monitoring",
          "body": "Jira and JSM customers using Microsoft OAuth for automatic creation of Jira tickets from email were unable to read email. This is now fixed and functional for all new incoming email processing.\n\nThe impacted customers during the incident period need to re-authorise the Microsoft mail server to restore and below are the instructions.\n\nTo re-authorise an incoming Microsoft mail server:\n\nLogin in Jira as Admin\nSelect  > System\nSelect Mail > Incoming Mail.\nSelect Edit incoming mail server.\nSelect re-authorise .\n\nEnter your Microsoft credentials to continue using your Microsoft mail server.",
          "incident_id": "gx3ch20w931s",
          "created_at": "2026-06-19T22:46:56.629Z",
          "updated_at": "2026-06-19T22:46:56.629Z",
          "display_at": "2026-06-19T22:46:56.629Z",
