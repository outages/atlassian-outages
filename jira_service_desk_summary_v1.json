    {
      "id": "1jtqjn8hvlsq",
      "name": "Excessive notifications being received by some Jira Service Management users",
      "status": "investigating",
      "created_at": "2026-05-14T01:15:35.189Z",
      "updated_at": "2026-05-14T05:03:32.642Z",
      "monitoring_at": null,
      "resolved_at": null,
      "impact": "critical",
      "shortlink": "https://stspg.io/sbqbvjppht1x",
      "started_at": "2026-05-14T01:15:35.183Z",
      "page_id": "pv54g7ltsc24",
      "incident_updates": [
        {
          "id": "7nsrshk2jlk0",
          "status": "investigating",
          "body": "Some of the users continue to experience an excessive number of notifications arriving from JSM (Assist) as our team replays delayed events experienced in this prior incident:\n\nhttps://jira-service-management.status.atlassian.com/incidents/v307yb60q5g7\n\nAt this time we expect that these notifications will be arriving for the next few hours, until the recovery of the delayed events are processed which is taking longer than expected (ETA approx. 4 hours). We will provide further updates within 6 hours or sooner if the recovery occurs.",
          "incident_id": "1jtqjn8hvlsq",
          "created_at": "2026-05-14T03:52:29.359Z",
          "updated_at": "2026-05-14T03:52:29.359Z",
          "display_at": "2026-05-14T03:52:29.359Z",
          "affected_components": [
            {
              "code": "6vlshpbyx93m",
              "name": "Assist",
              "old_status": "degraded_performance",
              "new_status": "degraded_performance"
            }
          ],
          "deliver_notifications": true,
          "custom_tweet": null,
          "tweet_id": null
        },
        {
          "id": "q1vcjf0nb131",
          "status": "investigating",
          "body": "We are aware that some users are experiencing an excessive number of notifications arriving from Jira Service Management (Assist) as our team replays delayed events experienced in this prior incident: \n\nhttps://jira-service-management.status.atlassian.com/incidents/v307yb60q5g7 \n\nAt this time we expect that the vast majority of these notifications will be arriving within the next two hours.\nWe will provide further update at that time or sooner if further information becomes available.",
          "incident_id": "1jtqjn8hvlsq",
