      "id": "sc66y9ljhjdc",
      "name": "Delays in processing incoming Emails, Work Item notifications, and Scheduled Triggers in Marketplace Apps",
      "status": "identified",
      "created_at": "2026-06-10T04:55:13.724Z",
      "updated_at": "2026-06-10T05:39:46.609Z",
      "monitoring_at": null,
      "resolved_at": null,
      "impact": "minor",
      "shortlink": "https://stspg.io/2pq565q12h85",
      "started_at": "2026-06-10T04:55:13.708Z",
      "page_id": "pv54g7ltsc24",
      "incident_updates": [
        {
          "id": "tr58vkb2343f",
          "status": "identified",
          "body": "Our team has identified the root cause for this issue and has now deployed a fix that is rolling out across impacted products. \n\nAt this time we are monitoring for the recovery of these events across Jira Service Management, Jira Cloud and Ecosystem app Scheduled Triggers.\n\nWe will provide further update within one hour or when we have seen a full recovery of all task processing across these products.",
          "incident_id": "sc66y9ljhjdc",
          "created_at": "2026-06-10T05:39:46.605Z",
          "updated_at": "2026-06-10T05:39:46.605Z",
