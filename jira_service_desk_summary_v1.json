      "id": "08r2yrfyj2qb",
      "name": "Voice call failures for some India based numbers",
      "status": "identified",
      "created_at": "2026-07-21T09:48:22.457Z",
      "updated_at": "2026-07-22T06:59:17.010Z",
      "monitoring_at": null,
      "resolved_at": null,
      "impact": "minor",
      "shortlink": "https://stspg.io/jnwlc1hc7c38",
      "started_at": "2026-07-21T09:48:22.444Z",
      "page_id": "pv54g7ltsc24",
      "incident_updates": [
        {
          "id": "pwp289qpzhs6",
          "status": "identified",
          "body": "A small number of voice notifications for Jira Service Management and Opsgenie customers using India based mobile numbers may fail. Customers may see failed voice call logs and not receive the expected paging call.\n\nOur 3rd party notification provider is actively working towards restoring the voice notification delivery and we will provide updates once the issue is resolved. If you need any further support or information, please reach out to our support team.",
