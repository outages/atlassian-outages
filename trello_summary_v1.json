        {
          "id": "zwgdf5nycq61",
          "status": "identified",
          "body": "We are continuing to monitor the index rebuild process across all affected shards and will provide updates as each phase completes. We will provide next update in eight hours or sooner as we make progress.",
          "incident_id": "h11gfkgvjhhk",
          "created_at": "2026-05-19T03:03:41.043-04:00",
          "updated_at": "2026-05-19T03:03:41.043-04:00",
          "display_at": "2026-05-19T03:03:41.043-04:00",
          "affected_components": [
            {
              "code": "y1nllgnkxn9d",
