        {
          "id": "827nvg22rqm4",
          "status": "monitoring",
          "body": "Index rebuild is complete and functionality should be restored for users. We are aware that cards moved by users during the incident may be in an incomplete state and we are investigating solutions.\n\nWe have no indication of data loss during the incident. We will continue to monitor and will provide the next updates in 4 hours or sooner.",
          "incident_id": "h11gfkgvjhhk",
          "created_at": "2026-05-19T10:26:04.334-04:00",
          "updated_at": "2026-05-19T10:26:04.334-04:00",
          "display_at": "2026-05-19T10:26:04.334-04:00",
          "affected_components": [
